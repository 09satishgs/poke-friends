{
  "manifest_version": 3,
  "name": "PokeFriends",
  "version": "1.1.0",
  "description": "Finds, stores, and copies Pokémon Go Friend Codes from the friendship megathread, syncing to GitHub securely.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "https://www.reddit.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "PokeFriends Helper"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.reddit.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
